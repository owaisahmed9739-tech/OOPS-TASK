// -->2) bankAccountSystem
class bankAccount{
    String accountHolder;
    double balance;
    public void depositAmount(double x){
        balance +=x;
    }
    public void withDrawAmount(double x){
        balance -=x;
        if(balance<=x){
            System.out.println("insuffient balance");
        }
    }
    public double getBalance(){
        return balance;
    }
}

